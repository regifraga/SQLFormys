# Template de variáveis de ambiente — SQLFormys
# Copie este arquivo para ".env" e preencha com seus valores reais.
# O arquivo ".env" NUNCA deve ser versionado.

# =============================================================
# Banco de Dados (Azure SQL Edge / SQL Server)
# =============================================================
SA_PASSWORD=SuaSenhaAqui
DB_DRIVER=sqlserver
DB_DSN=sqlserver://sa:SuaSenhaAqui@db:1433?database=master&encrypt=disable

# =============================================================
# API Backend (Go)
# =============================================================
PORT=8080
QUERIES_BASE_PATH=queries

# =============================================================
# Ambiente
# =============================================================
APP_ENV=production
API_BASE_URL=http://localhost:8080/api

